@using IHFiction.SharedWeb.Components.Authors
@inject MetadataUrlService MetadataUrls

@page "/authors"

<AuthorList
    EmitPaginationHeadLinks="true" />

<SocialPreviewMetadata
    Title="Authors | I❤️Fiction"
    Description="Discover fiction authors, browse their profiles, and follow their latest published stories and chapters on IHeartFiction."
    CanonicalUrl="@CanonicalUrl" />

<StructuredDataMetadata Schema="@AuthorsListSchema" />

@code {
    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    private int NormalizedPage => Page is > 0 ? Page.Value : 1;

    private string CanonicalUrl => NormalizedPage <= 1
        ? "/authors"
        : $"/authors?page={NormalizedPage}";

    private object AuthorsListSchema => new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "ItemList",
        ["@id"] = ToAbsolute($"{CanonicalUrl}#itemlist"),
        ["name"] = "Authors",
        ["url"] = ToAbsolute(CanonicalUrl)
    };

    private string ToAbsolute(string path) => MetadataUrls.ToAbsolute(path);
}
