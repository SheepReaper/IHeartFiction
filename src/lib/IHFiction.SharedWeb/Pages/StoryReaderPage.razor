@using System.Text
@using IHFiction.SharedWeb.Components.Reading
@implements IDisposable
@inject PersistentComponentState ApplicationState
@inject WorkService WorkService
@inject MetadataUrlService MetadataUrls

@page "/read/{WorkId}"

<SocialPreviewMetadata
    Title="@MetadataTitle"
    Description="@MetadataDescription"
    ImageUrl="@meta?.CoverImageUrl"
    PageUrl="@PageUrl"
    CanonicalUrl="@CanonicalUrl"
    EmitCanonical="@CanIndex"
    Type="article" />

@if (!CanIndex)
{
    <NoIndex />
}

<StructuredDataMetadata Schemas="@StructuredDataSchemas" />

@if (meta is { } loadedMeta)
{
    <StoryReader WorkId="@WorkId" Meta="@loadedMeta" />
}

@code {
    [Parameter] public string WorkId { get; set; } = null!;

    private LinkedOfGetPublishedWorkMetaResponse? meta;
    private string? loadedWorkId;
    private PersistingComponentStateSubscription persistingSubscription;

    private bool CanIndex => meta?.CanIndex == true;
    private string PageUrl => meta?.PageUrl ?? $"/read/{WorkId}";
    private string? CanonicalUrl => CanIndex ? meta?.CanonicalUrl ?? $"/read/{WorkId}" : null;

    private string MetadataTitle
    {
        get
        {
            if (meta is null) return "Read Work | I❤️Fiction";

            StringBuilder titleBuilder = new(meta.Title);

            if (!string.IsNullOrWhiteSpace(meta.BookTitle))
                titleBuilder.Append($" | {meta.BookTitle}");

            if (!string.IsNullOrWhiteSpace(meta.StoryTitle))
                titleBuilder.Append($" | {meta.StoryTitle}");

            titleBuilder.Append(" | I❤️Fiction");

            return titleBuilder.ToString();
        }
    }

    private string MetadataDescription => meta switch
    {
        null => "Read and share stories on IHeartFiction.",
        _ when !string.IsNullOrWhiteSpace(meta.Description) => meta.Description,
        _ => $"Start reading {meta.Title} on IHeartFiction."
    };

    protected override void OnInitialized()
    {
        persistingSubscription = ApplicationState.RegisterOnPersisting(PersistLoadedWorkMetadata);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (meta is not null && string.Equals(loadedWorkId, WorkId, StringComparison.Ordinal))
        {
            return;
        }

        meta = null;
        loadedWorkId = null;

        if (ApplicationState.TryTakeFromJson<LinkedOfGetPublishedWorkMetaResponse>(
            BuildStateKey(WorkId),
            out var persistedMeta)
            && persistedMeta is not null)
        {
            meta = persistedMeta;
            loadedWorkId = WorkId;
            return;
        }

        var result = await WorkService.GetPublishedWorkMetaAsync(WorkId);

        if (result.IsSuccess)
        {
            meta = result.Value;
            loadedWorkId = WorkId;
        }
        else
        {
            meta = null;
            loadedWorkId = null;
        }
    }

    private IEnumerable<object> StructuredDataSchemas
    {
        get
        {
            if (meta is null)
            {
                return [];
            }

            var workUrl = ToAbsolute(meta.CanonicalUrl ?? meta.PageUrl);
            var storyUrl = meta.StoryId is null ? null : ToAbsolute($"/stories/{meta.StoryId}");
            var authorSchemas = meta.Authors.Select(author => new Dictionary<string, object?>
            {
                ["@type"] = "Person",
                ["name"] = author.Name,
                ["url"] = ToAbsolute($"/authors/{author.Id}")
            }).ToList();

            var workSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = meta.WorkType == "Chapter" ? "Chapter" : "CreativeWork",
                ["@id"] = workUrl,
                ["name"] = meta.Title,
                ["headline"] = meta.Title,
                ["description"] = string.IsNullOrWhiteSpace(meta.Description) ? null : meta.Description,
                ["url"] = workUrl,
                ["image"] = string.IsNullOrWhiteSpace(meta.CoverImageUrl) ? null : new[] { ToAbsolute(meta.CoverImageUrl) },
                ["author"] = authorSchemas,
                ["publisher"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Organization",
                    ["name"] = "IHeartFiction",
                    ["url"] = ToAbsolute("/")
                },
                ["datePublished"] = meta.PublishedAt?.ToString("O"),
                ["dateModified"] = meta.UpdatedAt.ToString("O")
            };

            if (meta.WorkType == "Chapter" && storyUrl is not null)
            {
                workSchema["isPartOf"] = new Dictionary<string, object?>
                {
                    ["@type"] = "CreativeWork",
                    ["@id"] = storyUrl,
                    ["name"] = meta.StoryTitle,
                    ["url"] = storyUrl
                };
            }

            var breadcrumbItems = new List<Dictionary<string, object?>>
            {
                new()
                {
                    ["@type"] = "ListItem",
                    ["position"] = 1,
                    ["name"] = "Home",
                    ["item"] = ToAbsolute("/")
                },
                new()
                {
                    ["@type"] = "ListItem",
                    ["position"] = 2,
                    ["name"] = "Stories",
                    ["item"] = ToAbsolute("/stories")
                }
            };

            if (storyUrl is not null && meta.WorkType == "Chapter")
            {
                breadcrumbItems.Add(new()
                {
                    ["@type"] = "ListItem",
                    ["position"] = 3,
                    ["name"] = meta.StoryTitle,
                    ["item"] = storyUrl
                });
                breadcrumbItems.Add(new()
                {
                    ["@type"] = "ListItem",
                    ["position"] = 4,
                    ["name"] = meta.Title,
                    ["item"] = workUrl
                });
            }
            else
            {
                breadcrumbItems.Add(new()
                {
                    ["@type"] = "ListItem",
                    ["position"] = 3,
                    ["name"] = meta.Title,
                    ["item"] = workUrl
                });
            }

            var breadcrumbSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "BreadcrumbList",
                ["@id"] = $"{workUrl}#breadcrumb",
                ["itemListElement"] = breadcrumbItems
            };

            return [workSchema, breadcrumbSchema];
        }
    }

    private Task PersistLoadedWorkMetadata()
    {
        if (meta is not null && !string.IsNullOrWhiteSpace(loadedWorkId))
        {
            ApplicationState.PersistAsJson(BuildStateKey(loadedWorkId), meta);
        }

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        persistingSubscription.Dispose();
    }

    private string ToAbsolute(string url) => MetadataUrls.ToAbsolute(url);

    private static string BuildStateKey(string workId) => $"StoryReaderPage:WorkMeta:{workId}";
}
