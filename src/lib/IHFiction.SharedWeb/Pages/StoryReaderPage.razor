@using IHFiction.SharedWeb.Components.Reading
@inject StoryService StoryService

@page "/stories/{storyId}/read"

<SocialPreviewMetadata
    Title="@MetadataTitle"
    Description="@MetadataDescription"
    ImageUrl="@CoverImageUrl"
    CanonicalUrl="@CanonicalUrl"
    Type="article" />

<StoryReader StoryId="@StoryId" />

<HeadContent>
    <meta name="robots" content="noindex">
</HeadContent>

@code {
    [Parameter] public string StoryId { get; set; } = null!;

    private LinkedOfGetPublishedStoryResponse? story;

    private string CanonicalUrl => $"/stories/{StoryId}";

    private string MetadataTitle => story is null
        ? "Read Story | I❤️Fiction"
        : $"Read {story.Title} | I❤️Fiction";

    private string? CoverImageUrl => $"/stories/{StoryId}/cover";

    private string MetadataDescription => story switch
    {
        null => "Read and share stories on IHeartFiction.",
        _ when !string.IsNullOrWhiteSpace(story.Description) => story.Description,
        _ => $"Start reading {story.Title} on IHeartFiction."
    };

    protected override async Task OnParametersSetAsync()
    {
        var result = await StoryService.GetStoryAsync(StoryId);
        story = result.IsSuccess ? result.Value : null;
    }
}
