@page "/"
@using Sidio.Sitemap.Core
@inject Microsoft.Extensions.Options.IOptions<IHFiction.SharedWeb.Configuration.SiteUrlOptions> SiteUrlOptions

@attribute [Sitemap(ChangeFrequency.Yearly, 0.5, "2025-10-02")]

<SocialPreviewMetadata
    Title="I❤️Fiction - And So Do You"
    Description="Discover amazing stories from talented authors around the world. Read new chapters, explore story worlds, and support the creators you love." />

<StructuredDataMetadata Schemas="@HomeSchemas" />

<section class="hero is-primary is-medium">
    <div class="hero-body">
        <div class="container has-text-centered">
            <h1 class="title is-1">
                Welcome to I❤️Fiction
            </h1>

            <h2 class="subtitle is-3">
                Discover amazing stories from talented authors around the world
            </h2>
            <div class="buttons is-centered">
                <a href="/stories" class="button is-white is-large">
                    <span class="icon">
                        <i class="fas fa-book"></i>
                    </span>
                    <span>Browse Stories</span>
                </a>
                <a href="/authors" class="button has-background-link-soft has-text-link-bold is-large">
                    <span class="icon">
                        <i class="fas fa-users"></i>
                    </span>
                    <span>Browse Authors</span>
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    private string HomeUrl => ToAbsolute("/");

    private IEnumerable<object> HomeSchemas =>
    [
        new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Organization",
            ["@id"] = ToAbsolute("/#organization"),
            ["name"] = "IHeartFiction",
            ["url"] = HomeUrl,
            ["logo"] = ToAbsolute("/_content/IHFiction.SharedWeb/og-image.png"),
            ["description"] = "A modern fiction reading and publishing platform for original and fan fiction."
        },
        new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebSite",
            ["@id"] = ToAbsolute("/#website"),
            ["name"] = "IHeartFiction",
            ["url"] = HomeUrl,
            ["potentialAction"] = new Dictionary<string, object?>
            {
                ["@type"] = "SearchAction",
                ["target"] = $"{MetadataBaseUri.ToString().TrimEnd('/')}/stories?q={{search_term_string}}",
                ["query-input"] = "required name=search_term_string"
            }
        }
    ];

    private Uri MetadataBaseUri => GetMetadataBaseUri();

    private string ToAbsolute(string url)
    {
        var candidate = url.Trim();

        if (Uri.TryCreate(candidate, UriKind.Absolute, out var absoluteUri))
        {
            if (!string.Equals(absoluteUri.Scheme, Uri.UriSchemeFile, StringComparison.OrdinalIgnoreCase))
            {
                return absoluteUri.ToString();
            }

            candidate = string.IsNullOrWhiteSpace(absoluteUri.PathAndQuery)
                ? "/"
                : string.Concat(absoluteUri.PathAndQuery, absoluteUri.Fragment);
        }

        return new Uri(MetadataBaseUri, candidate).ToString();
    }

    private Uri GetMetadataBaseUri()
    {
        var baseUri = SiteUrlOptions.Value.BaseUrl;

        if (baseUri is null)
        {
            throw new InvalidOperationException("BaseUrl must be configured as an absolute URL.");
        }

        return baseUri;
    }
}

<section class="section">
    <div class="container">
        <div class="columns">
            <div class="column is-4">
                <div class="card">
                    <div class="card-content has-text-centered">
                        <div class="content">
                            <span class="icon is-large has-text-primary">
                                <i class="fas fa-book-open fa-3x"></i>
                            </span>
                            <h3 class="title is-4">Read Stories</h3>
                            <p>Immerse yourself in captivating stories from various genres. From romance to fantasy,
                                find your next favorite read.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column is-4">
                <div class="card">
                    <div class="card-content has-text-centered">
                        <div class="content">
                            <span class="icon is-large has-text-primary">
                                <i class="fas fa-user-edit fa-3x"></i>
                            </span>
                            <h3 class="title is-4">Discover Authors</h3>
                            <p>Discover talented writers and follow their creative journeys.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="column is-4">
                <div class="card">
                    <div class="card-content has-text-centered">
                        <div class="content">
                            <span class="icon is-large has-text-primary">
                                <i class="fas fa-heart fa-3x"></i>
                            </span>
                            <h3 class="title is-4">Share the Love</h3>
                            <p>Support your favorite authors and stories. Join a community of readers who appreciate
                                great storytelling.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>