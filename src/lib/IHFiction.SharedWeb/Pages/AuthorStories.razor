@using IHFiction.SharedWeb.Components.Stories
@using IHFiction.SharedWeb.Services
@using IHFiction.SharedKernel.Infrastructure
@inject PersistentComponentState ApplicationState
@implements IDisposable

@page "/authors/{authorId}/stories"

<SocialPreviewMetadata
    Title="@MetadataTitle"
    Description="@MetadataDescription"
    CanonicalUrl="@CanonicalUrl" />

<StoryList
    AuthorId="@AuthorId" />

@code {
    [Inject] AuthorService AuthorService { get; set; } = default!;

    [Parameter, EditorRequired] public string AuthorId { get; set; }
    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    private LinkedOfGetAuthorResponse? author;
    private string? _loadedAuthorId;
    private PersistingComponentStateSubscription _persistingSubscription;

    private int NormalizedPage => Page is > 0 ? Page.Value : 1;

    private string CanonicalUrl => NormalizedPage <= 1
        ? $"/authors/{AuthorId}/stories"
        : $"/authors/{AuthorId}/stories?page={NormalizedPage}";

    private string MetadataTitle => author?.Name != null
        ? $"{author.Name} - Stories | I❤️Fiction"
        : "Author Stories | I❤️Fiction";

    private string MetadataDescription => author?.Name != null
        ? $"Read stories by {author.Name}. Browse published works and jump directly into the latest chapters."
        : "Browse published stories from this author on IHeartFiction and jump directly into the latest chapters.";

    protected override void OnInitialized()
    {
        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistLoadedAuthorMetadata);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (author is not null && string.Equals(_loadedAuthorId, AuthorId, StringComparison.Ordinal))
        {
            return;
        }

        if (ApplicationState.TryTakeFromJson<LinkedOfGetAuthorResponse>(
            BuildStateKey(AuthorId),
            out var persistedAuthor)
            && persistedAuthor is not null)
        {
            author = persistedAuthor;
            _loadedAuthorId = AuthorId;
            return;
        }

        var result = await AuthorService.GetAuthorAsync(AuthorId);

        if (result.IsSuccess)
        {
            author = result.Value;
            _loadedAuthorId = AuthorId;
        }
        else
        {
            author = null;
            _loadedAuthorId = null;
        }
    }

    private Task PersistLoadedAuthorMetadata()
    {
        if (author is not null && !string.IsNullOrWhiteSpace(_loadedAuthorId))
        {
            ApplicationState.PersistAsJson(BuildStateKey(_loadedAuthorId), author);
        }

        return Task.CompletedTask;
    }

    public void Dispose()
    {
        _persistingSubscription.Dispose();
    }

    private static string BuildStateKey(string authorId) => $"AuthorStories:Author:{authorId}";
}
