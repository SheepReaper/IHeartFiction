@inject NavigationManager Navigation
@inject LoaderService LoaderService
@inject AccountService AccountService

@using System.Security.Cryptography
@using System.Text

<AuthorizeView>
    <Authorized>
        <div class="navbar-item has-dropdown @(_isMenuOpen ? "is-active" : string.Empty)">
            <a class="navbar-link" role="button" aria-label="User account menu" aria-haspopup="true" aria-expanded="@_isMenuOpen" tabindex="0" @onclick="ToggleMenu" @onkeydown="HandleMenuKeydown">
                @if (!string.IsNullOrEmpty(_avatarUrl))
                {
                    <figure class="image is-24x24">
                        <img class="is-rounded" src="@_avatarUrl" alt="@context.User.Identity?.Name" />
                    </figure>
                }
                else
                {
                    @(context.User.Identity?.Name)
                }
            </a>

            <div class="navbar-dropdown">
                @* <form action="authentication/logout" method="post">
                    <AntiforgeryToken />
                    <input type="hidden" name="ReturnUrl" value="@Navigation.Uri" />
                    <button type="submit" class="navbar-item">
                        Log out
                    </button>
                </form> *@
                <a class="navbar-item" @onclick="OnAccountSettingsClick">
                    Account Settings
                </a>
                <hr class="navbar-divider" />
                <a class="navbar-item" @onclick="OnLogoutClick" disabled="@_loading">
                    Log out
                </a>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="buttons">
            <button class="button is-primary" @onclick="OnSignUpClick" disabled="@_loading">
                <strong>Sign up</strong>
            </button>
            <button class="button has-background-link-soft has-text-link-bold" @onclick="OnLoginClick" disabled="@_loading">
                Log in
            </button>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [Parameter]
    public EventCallback OnActionInvoked { get; set; }

    private bool _loading;
    private string? _avatarUrl;
    private bool _isMenuOpen;

    protected override async Task OnInitializedAsync()
    {
        var result = await AccountService.GetUserProfileAsync();
        if (result.IsSuccess && !string.IsNullOrWhiteSpace(result.Value.GravatarEmail))
        {
            _avatarUrl = BuildGravatarUrl(result.Value.GravatarEmail);
        }
    }

    private static string? BuildGravatarUrl(string? email)
    {
        if (string.IsNullOrWhiteSpace(email)) return null;
        var normalized = email.Trim().ToLowerInvariant();
#pragma warning disable CA5351 // MD5 is required by Gravatar hashing protocol
        var hashBytes = MD5.HashData(Encoding.UTF8.GetBytes(normalized));
#pragma warning restore CA5351
#pragma warning disable CA1308 // Gravatar canonicalization requires lowercase
        var hash = Convert.ToHexString(hashBytes).ToLowerInvariant();
#pragma warning restore CA1308
        return $"https://www.gravatar.com/avatar/{hash}?s=24&d=mp&r=g";
    }

    private void ToggleMenu()
    {
        _isMenuOpen = !_isMenuOpen;
    }

    private void CloseMenu()
    {
        _isMenuOpen = false;
    }

    private void HandleMenuKeydown(KeyboardEventArgs e)
    {
        // Close menu on Escape key
        if (e.Key == "Escape" && _isMenuOpen)
        {
            CloseMenu();
        }
        // Toggle menu on Enter or Space key
        else if ((e.Key == "Enter" || e.Key == " ") && !_isMenuOpen)
        {
            ToggleMenu();
        }
    }

    private void OnSignUpClick() => OnLoginClick();

    private void OnLoginClick()
    {
        _loading = true;
        LoaderService.Show();
        Navigation.NavigateTo($"authentication/login?returnUrl={ReturnUrl ?? Navigation.Uri}", forceLoad: true);
    }

    private async Task OnLogoutClick()
    {
        CloseMenu();
        await NotifyActionInvokedAsync();
        _loading = true;
        LoaderService.Show();
        Navigation.NavigateTo($"authentication/logout", forceLoad: true);
    }

    private async Task OnAccountSettingsClick()
    {
        CloseMenu();
        await NotifyActionInvokedAsync();
        Navigation.NavigateTo("account/settings");
    }

    private Task NotifyActionInvokedAsync()
    {
        return OnActionInvoked.HasDelegate
            ? OnActionInvoked.InvokeAsync()
            : Task.CompletedTask;
    }
}