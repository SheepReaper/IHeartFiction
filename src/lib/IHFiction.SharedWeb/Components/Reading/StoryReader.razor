@using Markdig
@using IHFiction.SharedWeb.Services
@inherits CancellableComponent
@inject WorkService WorkService
@inject ReaderProgressService ReaderProgressService
@inject NavigationManager Navigation
@inject ThemeService theme
@inject MarkdownPipeline mdp

@if (isLoading)
{
    <div class="section">
        <div class="content has-text-centered">
            <span class="icon is-large">
                <i class="fas fa-spinner fa-pulse fa-2x"></i>
            </span>
            <p>Loading...</p>
        </div>
    </div>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="section">
        <div class="container">
            <div class="notification is-danger">
                <strong>Error:</strong> @errorMessage
            </div>
        </div>
    </div>
}
else if (Meta is not null)
{
    var orderedChildren = BuildNavigationChapters().ToList();
    var currentChapterIndex = orderedChildren.FindIndex(chapter => chapter.Id == WorkId);
    var currentChapter = currentChapterIndex >= 0 ? orderedChildren[currentChapterIndex] : null;
    var nextChapter = currentChapterIndex >= 0 && currentChapterIndex < orderedChildren.Count - 1
        ? orderedChildren[currentChapterIndex + 1]
        : null;
    var isCrossBookTransition =
        nextChapter is not null
        && currentChapter is not null
        && !string.IsNullOrWhiteSpace(nextChapter.BookTitle)
        && !string.Equals(nextChapter.BookTitle, currentChapter.BookTitle, StringComparison.OrdinalIgnoreCase);
    var isEndOfStory = Meta.WorkType == "Chapter" && nextChapter is null && orderedChildren.Count > 0;

    <div class="section">
        <div class="container">
            <div class="level ihf-reader-header">
                <div class="level-left">
                    <div class="level-item">
                        <div>
                            <h1 class="title is-4 mb-1">@Meta.Title</h1>
                            @if (!string.IsNullOrWhiteSpace(Byline))
                            {
                                <p class="subtitle is-6 mb-0">@Byline</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="level-right">
                    <div class="level-item">
                        <div class="buttons">
                            @if (orderedChildren.Count > 1 && Meta.WorkType == "Chapter")
                            {
                                <ChapterNavigation
                                    CurrentChapterId="@WorkId"
                                    Chapters="@orderedChildren" />
                            }
                            @if (Meta.StoryId is not null)
                            {
                                <a href="/stories/@Meta.StoryId" class="button has-background-info-soft has-text-info-bold">
                                    <span class="icon">
                                        <i class="fas fa-info-circle"></i>
                                    </span>
                                    <span>Story Details</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (content is not null)
            {
                <div class="content">
                    @if (!string.IsNullOrWhiteSpace(content.Note1))
                    {
                        <div class="message is-info">
                            <div class="message-header">
                                <p>Author's Notes</p>
                            </div>
                            <div class="message-body">
                                <div class="content">@((MarkupString)Markdown.ToHtml(content.Note1, mdp))</div>
                            </div>
                        </div>
                    }

                    <div class="box content ihf-reader-body">
                        @((MarkupString)Markdown.ToHtml(content.Content, mdp))
                    </div>

                    @if (!string.IsNullOrWhiteSpace(content.Note2))
                    {
                        <div class="message is-info">
                            <div class="message-header">
                                <p>Author's Notes</p>
                            </div>
                            <div class="message-body">
                                <div class="content">@((MarkupString)Markdown.ToHtml(content.Note2, mdp))</div>
                            </div>
                        </div>
                    }

                    @if (isCrossBookTransition && nextChapter is not null && currentChapter is not null)
                    {
                        <div class="notification has-background-info-soft has-text-info-bold">
                            <p>
                                You finished @currentChapter.BookTitle. Next up: @nextChapter.BookTitle.
                            </p>
                            <p class="mt-2">
                                <a class="button has-background-primary-soft has-text-primary-bold" href="@ReadHref(nextChapter.Id)">
                                    Continue to @nextChapter.BookTitle
                                </a>
                            </p>
                        </div>
                    }
                    else if (isEndOfStory)
                    {
                        <div class="notification has-background-success-soft has-text-success-bold">
                            <p>You've reached the end of this story.</p>
                            @if (Meta.StoryId is not null)
                            {
                                <p class="mt-2">
                                    <a class="button has-background-info-soft has-text-info-bold" href="/stories/@Meta.StoryId">
                                        Back to Story Details
                                    </a>
                                </p>
                            }
                        </div>
                    }

                    <div class="level mt-6">
                        <div class="level-left">
                            <div class="level-item">
                                <ChapterNavigation
                                    CurrentChapterId="@WorkId"
                                    Chapters="@orderedChildren"
                                    ShowLabels="true" />
                            </div>
                        </div>
                        <div class="level-right">
                            <div class="level-item">
                                <p class="is-size-7">
                                    Last updated: @content.ContentUpdatedAt.ToString("MMM dd, yyyy")
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (Meta.IsDirectlyReadable)
            {
                <div class="content has-text-centered">
                    <span class="icon is-large">
                        <i class="fas fa-file-alt fa-3x"></i>
                    </span>
                    <h2 class="title is-4">No content available</h2>
                    <p>This work doesn't have any content yet.</p>
                </div>
            }
            else
            {
                <div class="content has-text-centered">
                    <span class="icon is-large">
                        <i class="fas fa-spinner fa-pulse fa-2x"></i>
                    </span>
                    <p>Finding your place...</p>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string WorkId { get; set; } = null!;
    [Parameter, EditorRequired] public LinkedOfGetPublishedWorkMetaResponse Meta { get; set; } = null!;

    private LinkedOfGetPublishedWorkContentResponse? content;
    private bool isLoading = true;
    private string? errorMessage;
    private string? loadedContentWorkId;
    private string? appliedParameterKey;
    private string? handledParameterKey;
    private bool _disposed;

    private string? Byline => Meta?.Authors?.Any() == true
        ? $"by {string.Join(", ", Meta.Authors.Select(a => a.Name))}"
        : null;

    protected override void OnInitialized()
    {
        theme.ThemeChanged += OnThemeChanged;
    }

    protected override void OnParametersSet()
    {
        var parameterKey = BuildParameterKey();
        if (appliedParameterKey == parameterKey)
        {
            return;
        }

        content = null;
        errorMessage = null;
        isLoading = Meta is null || Meta.IsDirectlyReadable;
        appliedParameterKey = parameterKey;
        handledParameterKey = null;
        loadedContentWorkId = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var parameterKey = BuildParameterKey();
        if (Meta is null || handledParameterKey == parameterKey)
        {
            return;
        }

        handledParameterKey = parameterKey;

        if (!Meta.IsDirectlyReadable)
        {
            await NavigateToSelectedReadableWorkAsync();
            return;
        }

        await LoadContentAsync();
    }

    private async Task LoadContentAsync()
    {
        if (loadedContentWorkId == WorkId)
        {
            return;
        }

        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            var result = await WorkService.GetPublishedWorkContentAsync(WorkId, cancellationToken: CancellationToken);

            if (result.IsSuccess)
            {
                content = result.Value;
                loadedContentWorkId = WorkId;

                if (Meta?.WorkType == "Chapter" && Meta.StoryId is not null)
                {
                    await ReaderProgressService.SetLastReadChapterIdAsync(Meta.StoryId.ToString()!, WorkId);
                }
            }
            else
            {
                content = null;
                errorMessage = result.DomainError.Description;
            }
        }
        catch (OperationCanceledException) when (CancellationToken.IsCancellationRequested)
        {
            return;
        }
        catch (Exception ex)
        {
            content = null;
            errorMessage = $"Failed to load this work's content: {ex.Message}";
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task NavigateToSelectedReadableWorkAsync()
    {
        isLoading = true;
        StateHasChanged();

        var storyProgressId = Meta?.StoryId?.ToString() ?? WorkId;
        var targetWorkId = await ReaderProgressService.GetLastReadChapterIdAsync(storyProgressId);
        var readableChildren = Meta?.ReadableChildren?.ToList() ?? [];

        if (string.IsNullOrWhiteSpace(targetWorkId)
            || !readableChildren.Any(child => child.Id.ToString() == targetWorkId))
        {
            targetWorkId = Meta?.DefaultReadableWorkId?.ToString();
        }

        if (!string.IsNullOrWhiteSpace(targetWorkId))
        {
            Navigation.NavigateTo($"/read/{targetWorkId}", replace: true);
            return;
        }

        isLoading = false;
        errorMessage = "This work does not have any published readable content yet.";
        StateHasChanged();
    }

    private IEnumerable<ReaderChapterNavItem> BuildNavigationChapters()
    {
        return Meta?.ReadableChildren?
            .OrderBy(child => child.BookId?.ToString() ?? string.Empty)
            .ThenBy(child => child.Order)
            .Select(child => new ReaderChapterNavItem(
                child.Id.ToString(),
                child.Title,
                child.Order,
                child.BookTitle))
            .ToList() ?? [];
    }

    private void OnThemeChanged(object? sender, ThemeChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    protected override ValueTask DisposeAsyncCore()
    {
        if (_disposed)
        {
            return ValueTask.CompletedTask;
        }

        theme.ThemeChanged -= OnThemeChanged;
        _disposed = true;

        return base.DisposeAsyncCore();
    }

    private static string ReadHref(string workId) => $"/read/{workId}";

    private string BuildParameterKey() => $"{WorkId}:{Meta?.Id.ToString() ?? "none"}";
}
