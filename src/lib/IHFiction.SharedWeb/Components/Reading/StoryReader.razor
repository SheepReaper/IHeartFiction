@using Markdig
@using System.Linq
@using IHFiction.SharedWeb.Components.Reading
@using IHFiction.SharedWeb.Services
@using static IHFiction.Data.Stories.Domain.StoryType
@inherits CancellableComponent
@inject StoryService StoryService
@inject ReaderProgressService ReaderProgressService
@inject ThemeService theme
@inject IJSRuntime js
@inject MarkdownPipeline mdp

@if (isLoading)
{
    <div class="section">
        <div class="content has-text-centered">
            <span class="icon is-large">
                <i class="fas fa-file-alt fa-3x"></i>
            </span>
            <h2 class="title is-4">No content available</h2>
            <p>This story doesn't have any content yet.</p>
        </div>
    </div>
}
else if (story != null)
{
    <div class="section">
        <div class="container">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="notification is-danger">
                    <button class="delete" @onclick="e => errorMessage = null"></button>
                    @errorMessage
                </div>
            }
            <!-- Story Header -->
            <div class="level">
                <div class="level-left">
                    <div class="level-item">
                        <div>
                            <h1 class="title is-3">@story?.Title</h1>
                            <p class="subtitle is-5">
                                by @foreach (var author in story?.Authors ?? [])
                                {
                                    <a @key="author.Id" href="/authors/@author.Id" class="ihf-content-link">@author.Name</a>
                                    @if (author != story?.Authors.Last())
                                    {
                                        <text>, </text>
                                    }
                                }
                            </p>
                        </div>
                    </div>
                </div>
                <div class="level-right">
                    <div class="level-item">
                        <div class="buttons">
                            @if (story?.Type is MultiBook or MultiChapter)
                            {
                                <button class="button has-background-primary-soft has-text-primary-bold" @onclick="OpenContentsModal">
                                    <span class="icon">
                                        <i class="fas fa-list"></i>
                                    </span>
                                    <span>Contents</span>
                                </button>
                            }
                            <a href="/stories/@story?.Id" class="button has-background-info-soft has-text-info-bold">
                                <span class="icon">
                                    <i class="fas fa-info-circle"></i>
                                </span>
                                <span>Story Details</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            @switch (story?.Type)
            {
                case MultiBook:
                    <div class="content">
                        @if (!string.IsNullOrEmpty(CurrentChapterId))
                        {
                            <ChapterReader StoryId="@StoryId" ChapterId="@CurrentChapterId" Chapters="@(navigationChapters ?? [])" />
                        }
                        else
                        {
                            <div class="content has-text-centered">
                                <h2 class="title is-4">Select a Chapter</h2>
                                <p>Open Contents to start reading.</p>
                            </div>
                        }
                    </div>
                    break;
                case MultiChapter:
                    <div class="content">
                        @if (!string.IsNullOrEmpty(CurrentChapterId))
                        {
                            <ChapterReader StoryId="@StoryId" ChapterId="@CurrentChapterId" Chapters="@(chapters ?? [])" />
                        }
                        else
                        {
                            <div class="content has-text-centered">
                                <h2 class="title is-4">Select a Chapter</h2>
                                <p>Open Contents to start reading.</p>
                            </div>
                        }
                    </div>
                    break;
                default: // SingleBody
                    @if (storyContent != null)
                    {
                        <div class="content">
                            @if (!string.IsNullOrWhiteSpace(storyContent.Note1))
                            {
                                <div class="message is-info">
                                    <div class="message-header">
                                        <p>Author's Notes</p>
                                    </div>
                                    <div class="message-body">
                                        <div class="content">@((MarkupString)Markdown.ToHtml(storyContent.Note1, mdp))</div>
                                    </div>
                                </div>
                            }
                            <div class="box content">
                                @((MarkupString)Markdown.ToHtml(storyContent?.Content ?? string.Empty, mdp))
                            </div>
                            @if (!string.IsNullOrWhiteSpace(storyContent?.Note2))
                            {
                                <div class="message is-info">
                                    <div class="message-header">
                                        <p>Author's Notes</p>
                                    </div>
                                    <div class="message-body">
                                        <div class="content">@((MarkupString)Markdown.ToHtml(storyContent.Note2, mdp))</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="content has-text-centered">
                            <span class="icon is-large">
                                <i class="fas fa-file-alt fa-3x"></i>
                            </span>
                            <h2 class="title is-4">No content available</h2>
                            <p>This story doesn't have any content yet.</p>
                        </div>
                    }
                    break;
            }

            <div class="modal @(isContentsModalOpen ? "is-active" : string.Empty)">
                <div class="modal-background" @onclick="CloseContentsModal"></div>
                <div class="modal-card">
                    <header class="modal-card-head">
                        <p class="modal-card-title">Chapter Contents</p>
                        <button class="delete" aria-label="close" @onclick="CloseContentsModal"></button>
                    </header>
                    <section class="modal-card-body">
                        @if (story?.Type == MultiBook)
                        {
                            <aside class="menu">
                                <p class="menu-label">Books</p>
                                <ul class="menu-list">
                                    @if (story.Books?.Any() ?? false)
                                    {
                                        foreach (var book in story.Books.OrderBy(b => b.Order))
                                        {
                                            <li @key="book.Id">
                                                <a class="@(book.Id.ToString() == CurrentBookId ? "is-active" : "")"
                                                   @onclick="e => SelectBook(book.Id.ToString())">
                                                    @book.Title
                                                </a>
                                                @if (book.Chapters?.Any() ?? false)
                                                {
                                                    <ul>
                                                        @foreach (var chapter in book.Chapters.OrderBy(c => c.Order))
                                                        {
                                                            <li @key="chapter.Id">
                                                                <a href="/stories/@story.Id/chapters/@chapter.Id"
                                                                   class="@(chapter.Id.ToString() == CurrentChapterId ? "is-active" : "")"
                                                                   @onclick="@(e => SelectChapter(book.Id.ToString(), chapter.Id.ToString()))">
                                                                    @chapter.Title
                                                                </a>
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                            </li>
                                        }
                                    }
                                </ul>
                            </aside>
                        }
                        else if (story?.Type == MultiChapter)
                        {
                            <aside class="menu">
                                <p class="menu-label">Chapters</p>
                                <ul class="menu-list">
                                    @if (chapters?.Any() ?? false)
                                    {
                                        foreach (var chapter in chapters)
                                        {
                                            <li @key="chapter.Id">
                                                <a href="/stories/@story.Id/chapters/@chapter.Id"
                                                   class="@(chapter.Id.ToString() == CurrentChapterId ? "is-active" : "")"
                                                   @onclick="e => SelectChapter(null, chapter.Id.ToString())">
                                                    @chapter.Title
                                                </a>
                                            </li>
                                        }
                                    }
                                </ul>
                            </aside>
                        }
                    </section>
                    <footer class="modal-card-foot">
                        <button class="button" @onclick="CloseContentsModal">Close</button>
                    </footer>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string StoryId { get; set; } = null!;
    [Parameter] public string? CurrentChapterId { get; set; }

    private LinkedOfGetPublishedStoryResponse? story;
    private IEnumerable<ReaderChapterNavItem>? chapters;
    private IEnumerable<ReaderChapterNavItem>? navigationChapters;
    private LinkedOfGetPublishedStoryContentResponse? storyContent;
    private bool isLoading = true;
    private bool isContentsModalOpen;
    private string? errorMessage;
    private string? lastSavedChapterId;
    private bool attemptedProgressRestore;
    private bool _disposed = false;

    protected override async Task OnInitializedAsync()
    {
        theme.ThemeChanged += OnThemeChanged;
        await LoadStory();
        SetTheme();
    }

    private void OnThemeChanged(object? sender, ThemeChangedEventArgs e)
    {
        SetTheme();
    }

    private void SetTheme()
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (story?.Id.ToString() != StoryId)
        {
            await LoadStory();
            return;
        }

        if (story?.Type == MultiBook && !string.IsNullOrEmpty(CurrentChapterId))
        {
            SyncCurrentBookFromChapter(CurrentChapterId);
            await SaveReaderProgressAsync(CurrentChapterId);
        }

        if (story?.Type == MultiChapter && !string.IsNullOrEmpty(CurrentChapterId))
        {
            await SaveReaderProgressAsync(CurrentChapterId);
        }
    }

    private async Task LoadStory()
    {
        isLoading = true;
        errorMessage = null;

        var storyResult = await StoryService.GetStoryAsync(StoryId);

        if (storyResult.IsSuccess)
        {
            story = storyResult.Value;

            if (story?.Type == MultiBook)
            {
                if (story.Books?.Any() == true)
                {
                    navigationChapters = story.Books
                        .OrderBy(b => b.Order)
                        .SelectMany(b => (b.Chapters ?? []).OrderBy(c => c.Order)
                            .Select(c => new ReaderChapterNavItem(
                                c.Id.ToString(),
                                c.Title,
                                c.Order,
                                b.Title)))
                        .ToList();

                    if (string.IsNullOrEmpty(CurrentChapterId))
                    {
                        var restoredChapterId = await TryRestoreReaderProgressAsync();
                        if (!string.IsNullOrEmpty(restoredChapterId))
                        {
                            CurrentChapterId = restoredChapterId;
                        }
                    }

                    if (!string.IsNullOrEmpty(CurrentChapterId))
                    {
                        SyncCurrentBookFromChapter(CurrentChapterId);
                        await SaveReaderProgressAsync(CurrentChapterId);
                    }

                    // Auto-select the first book and chapter by Order if no current chapter is set.
                    if (string.IsNullOrEmpty(CurrentBookId))
                    {
                        var firstBook = story.Books.OrderBy(b => b.Order).First();
                        CurrentBookId = firstBook.Id.ToString();
                        chapters = firstBook.Chapters?.OrderBy(c => c.Order)
                            .Select(c => new ReaderChapterNavItem(c.Id.ToString(), c.Title, c.Order, firstBook.Title))
                            .ToList();

                        if (string.IsNullOrEmpty(CurrentChapterId) && firstBook.Chapters?.Any() == true)
                        {
                            CurrentChapterId = firstBook.Chapters.OrderBy(c => c.Order).First().Id.ToString();
                            await SaveReaderProgressAsync(CurrentChapterId);
                        }
                    }
                }
            }
            else if (story?.Type == MultiChapter)
            {
                chapters = story.Chapters?.OrderBy(c => c.Order)
                    .Select(c => new ReaderChapterNavItem(c.Id.ToString(), c.Title, c.Order))
                    .ToList();
                navigationChapters = chapters;

                if (string.IsNullOrEmpty(CurrentChapterId))
                {
                    var restoredChapterId = await TryRestoreReaderProgressAsync();
                    if (!string.IsNullOrEmpty(restoredChapterId))
                    {
                        CurrentChapterId = restoredChapterId;
                    }
                }

                // Auto-select the first chapter by Order if none is selected
                if (string.IsNullOrEmpty(CurrentChapterId) && (chapters?.Any() ?? false))
                {
                    CurrentChapterId = chapters!.First().Id;
                }

                if (!string.IsNullOrEmpty(CurrentChapterId))
                {
                    await SaveReaderProgressAsync(CurrentChapterId);
                }
            }
            else if (story?.Type == SingleBody)
            {
                navigationChapters = [];
                // Load content for single story
                var contentResult = await StoryService.GetPublishedStoryContentAsync(StoryId);

                if (contentResult.IsSuccess)
                {
                    storyContent = contentResult.Value;
                }
            }
        }
        else
        {
            errorMessage = storyResult.DomainError.Description;
        }

        isLoading = false;
        StateHasChanged();
    }

    protected override ValueTask DisposeAsyncCore()
    {
        if (_disposed) return ValueTask.CompletedTask;

        theme.ThemeChanged -= OnThemeChanged;

        _disposed = true;

        return base.DisposeAsyncCore();
    }
    private string? CurrentBookId;

    private void SyncCurrentBookFromChapter(string chapterId)
    {
        if (story?.Books?.Any() != true)
        {
            return;
        }

        var containingBook = story.Books
            .OrderBy(b => b.Order)
            .FirstOrDefault(book => book.Chapters?.Any(chapter => chapter.Id.ToString() == chapterId) == true);

        if (containingBook == null)
        {
            return;
        }

        CurrentBookId = containingBook.Id.ToString();
        chapters = containingBook.Chapters?.OrderBy(c => c.Order)
            .Select(c => new ReaderChapterNavItem(c.Id.ToString(), c.Title, c.Order, containingBook.Title))
            .ToList();
    }

    private void SelectBook(string bookId)
    {
        CurrentBookId = bookId;
        // Auto-select first chapter in the book (by Order) if available
        var book = story?.Books?.FirstOrDefault(b => b.Id.ToString() == bookId);
        if (book?.Chapters?.Any() == true)
        {
            chapters = book.Chapters.OrderBy(c => c.Order)
                .Select(c => new ReaderChapterNavItem(c.Id.ToString(), c.Title, c.Order, book.Title))
                .ToList();
            CurrentChapterId = book.Chapters.OrderBy(c => c.Order).First().Id.ToString();
            _ = SaveReaderProgressAsync(CurrentChapterId);
        }
        else
        {
            CurrentChapterId = null;
        }
    }

    private void SelectChapter(string? bookId, string chapterId)
    {
        if (bookId != null)
            CurrentBookId = bookId;

        CurrentChapterId = chapterId;
        _ = SaveReaderProgressAsync(chapterId);
        CloseContentsModal();
    }

    private async Task<string?> TryRestoreReaderProgressAsync()
    {
        if (attemptedProgressRestore)
        {
            return null;
        }

        attemptedProgressRestore = true;

        var chapterId = await ReaderProgressService.GetLastReadChapterIdAsync(StoryId);
        if (string.IsNullOrWhiteSpace(chapterId))
        {
            return null;
        }

        if (navigationChapters?.Any(c => c.Id == chapterId) != true)
        {
            await ReaderProgressService.ClearLastReadChapterIdAsync(StoryId);
            return null;
        }

        return chapterId;
    }

    private async Task SaveReaderProgressAsync(string chapterId)
    {
        if (string.IsNullOrWhiteSpace(chapterId) || chapterId == lastSavedChapterId)
        {
            return;
        }

        lastSavedChapterId = chapterId;
        await ReaderProgressService.SetLastReadChapterIdAsync(StoryId, chapterId);
    }

    private void OpenContentsModal()
    {
        isContentsModalOpen = true;
    }

    private void CloseContentsModal()
    {
        isContentsModalOpen = false;
    }
}