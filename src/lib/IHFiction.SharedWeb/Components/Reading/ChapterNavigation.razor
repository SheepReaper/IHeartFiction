@if (Chapters.Any())
{
    var chapters = Chapters.ToList();
    var currentIndex = chapters.FindIndex(c => c.Id == CurrentChapterId);
    var previousChapter = currentIndex > 0 ? chapters[currentIndex - 1] : null;
    var nextChapter = currentIndex >= 0 && currentIndex < chapters.Count - 1 ? chapters[currentIndex + 1]
    : null;
    var currentChapter = currentIndex >= 0 ? chapters[currentIndex] : null;

    <div class="field is-grouped is-grouped-multiline ihf-chapter-nav">
        @if (previousChapter != null)
        {
            <div class="control">
                <a class="button" href="@ChapterHref(previousChapter.Id.ToString())" title="@BuildTargetLabel("Previous", previousChapter, currentChapter)">
                    <span class="icon">
                        <i class="fas fa-chevron-left"></i>
                    </span>
                    @if (ShowLabels)
                    {
                        <span>@BuildTargetLabel("Previous", previousChapter, currentChapter)</span>
                    }
                </a>
            </div>
        }
        else if (ShowLabels)
        {
            <div class="control">
                <button class="button" disabled>
                    <span class="icon">
                        <i class="fas fa-chevron-left"></i>
                    </span>
                    <span>Previous</span>
                </button>
            </div>
        }

        @if (ShowLabels && currentIndex >= 0)
        {
            <div class="control">
                <span class="button is-static">
                    Chapter @(currentIndex + 1) of @chapters.Count
                </span>
            </div>
        }

        @if (nextChapter != null)
        {
            <div class="control">
                <a class="button" href="@ChapterHref(nextChapter.Id.ToString())" title="@BuildTargetLabel("Next", nextChapter, currentChapter)">
                    @if (ShowLabels)
                    {
                        <span>@BuildTargetLabel("Next", nextChapter, currentChapter)</span>
                    }
                    <span class="icon">
                        <i class="fas fa-chevron-right"></i>
                    </span>
                </a>
            </div>
        }
        else if (ShowLabels)
        {
            <div class="control">
                <button class="button" disabled>
                    <span>Next</span>
                    <span class="icon">
                        <i class="fas fa-chevron-right"></i>
                    </span>
                </button>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string? StoryId { get; set; }
    [Parameter, EditorRequired] public string CurrentChapterId { get; set; } = null!;
    [Parameter] public IEnumerable<ReaderChapterNavItem> Chapters { get; set; } = [];
    [Parameter] public bool ShowLabels { get; set; } = false;

    private static string ChapterHref(string chapterId) => $"/read/{chapterId}";

    private static string BuildTargetLabel(string direction, ReaderChapterNavItem target, ReaderChapterNavItem? current)
    {
        if (string.IsNullOrWhiteSpace(target.BookTitle)
            || current == null
            || string.Equals(target.BookTitle, current.BookTitle, StringComparison.OrdinalIgnoreCase))
        {
            return direction;
        }

        return $"{direction}: {target.BookTitle} · {target.Title}";
    }
}
