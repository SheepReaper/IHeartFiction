@using Markdig
@inject ChapterService ChapterService
@inject MarkdownPipeline mdp
@inject MetadataUrlService MetadataUrls

<SocialPreviewMetadata
    Title="@MetadataTitle"
    Description="@MetadataDescription"
    ImageUrl="@CoverImageUrl"
    Type="article" />

<StructuredDataMetadata Schemas="@StructuredDataSchemas" />


@if (isLoading)
{
    <div class="has-text-centered">
        <span class="icon is-large">
            <i class="fas fa-spinner fa-pulse fa-2x"></i>
        </span>
        <p>Loading chapter...</p>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="notification is-danger">
        <strong>Error:</strong> @errorMessage
    </div>
}
else if (chapterContent != null)
{
    var orderedChapters = Chapters.ToList();
    var currentChapterIndex = orderedChapters.FindIndex(chapter => chapter.Id == ChapterId);
    var currentChapter = currentChapterIndex >= 0 ? orderedChapters[currentChapterIndex] : null;
    var nextChapter = currentChapterIndex >= 0 && currentChapterIndex < orderedChapters.Count - 1
        ? orderedChapters[currentChapterIndex + 1]
        : null;
    var isCrossBookTransition =
        nextChapter != null
        && currentChapter != null
        && !string.IsNullOrWhiteSpace(nextChapter.BookTitle)
        && !string.Equals(nextChapter.BookTitle, currentChapter.BookTitle, StringComparison.OrdinalIgnoreCase);
    var isEndOfStory = nextChapter == null && orderedChapters.Count > 0;

    <div class="content">
        <div class="level">
            <div class="level-left">
                <div class="level-item">
                    <h2 class="title is-4">@chapterContent.ChapterTitle</h2>
                </div>
            </div>
            <div class="level-right">
                <div class="level-item">
                    <ChapterNavigation StoryId="@StoryId" CurrentChapterId="@ChapterId" Chapters="Chapters" />
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(chapterContent.Note1))
        {
            <div class="message is-info">
                <div class="message-header">
                    <p>Author's Notes</p>
                </div>
                <div class="message-body">
                    @if (!string.IsNullOrWhiteSpace(chapterContent.Note1))
                    {
                        <div class="content">@((MarkupString)Markdown.ToHtml(chapterContent.Note1, mdp))</div>
                    }
                </div>
            </div>
        }

        <div class="box content">
            @((MarkupString)Markdown.ToHtml(chapterContent.Content, mdp))
        </div>

        @if (!string.IsNullOrWhiteSpace(chapterContent.Note2))
        {
            <div class="message is-info">
                <div class="message-header">
                    <p>Author's Notes</p>
                </div>
                <div class="message-body">
                    @if (!string.IsNullOrWhiteSpace(chapterContent.Note2))
                    {
                        <div class="content">@((MarkupString)Markdown.ToHtml(chapterContent.Note2, mdp))</div>
                    }
                </div>
            </div>
        }

        @if (isCrossBookTransition && nextChapter != null && currentChapter != null)
        {
            <div class="notification has-background-info-soft has-text-info-bold">
                <p>
                    You finished @currentChapter.BookTitle. Next up: @nextChapter.BookTitle.
                </p>
                <p class="mt-2">
                    <a class="button has-background-primary-soft has-text-primary-bold" href="@ChapterHref(nextChapter.Id)">
                        Continue to @nextChapter.BookTitle
                    </a>
                </p>
            </div>
        }
        else if (isEndOfStory)
        {
            <div class="notification has-background-success-soft has-text-success-bold">
                <p>You've reached the end of this story.</p>
                <p class="mt-2">
                    <a class="button has-background-info-soft has-text-info-bold" href="/stories/@StoryId">
                        Back to Story Details
                    </a>
                </p>
            </div>
        }

        <div class="level mt-6">
            <div class="level-left">
                <div class="level-item">
                    <ChapterNavigation StoryId="@StoryId" CurrentChapterId="@ChapterId" Chapters="Chapters" ShowLabels="true" />
                </div>
            </div>
            <div class="level-right">
                <div class="level-item">
                    <p class="is-size-7">
                        Last updated: @chapterContent.ContentUpdatedAt.ToString("MMM dd, yyyy")
                    </p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string StoryId { get; set; } = null!;
    [Parameter, EditorRequired] public string ChapterId { get; set; } = null!;
    [Parameter] public IEnumerable<ReaderChapterNavItem> Chapters { get; set; } = [];

    public string PageTitle => string.Join(" - ", new[] {
        chapterContent?.ChapterTitle,
        chapterContent?.BookTitle,
        chapterContent?.StoryTitle }.Where(s => !string.IsNullOrWhiteSpace(s))) ?? "Reading | I❤️Fiction";

    private string MetadataTitle => chapterContent is null
        ? "Reading Chapter | I❤️Fiction"
        : $"{PageTitle} | I❤️Fiction";

    private string MetadataDescription => chapterContent switch
    {
        null => "Read chapter updates and continue the story on IHeartFiction.",
        _ when !string.IsNullOrWhiteSpace(chapterContent.Content) => chapterContent.Content,
        _ => $"Read {chapterContent?.ChapterTitle ?? "the latest chapter"} from {chapterContent?.StoryTitle ?? "this story"} on IHeartFiction."
    };

    private LinkedOfGetPublishedChapterContentResponse? chapterContent;
    private bool isLoading = true;
    private string? errorMessage;

    private string? CoverImageUrl => chapterContent is {} ? $"/stories/{chapterContent.StoryId}/cover" : null;

    private IEnumerable<object> StructuredDataSchemas
    {
        get
        {
            if (chapterContent is null)
            {
                return [];
            }

            var chapterUrl = ToAbsolute($"/stories/{chapterContent.StoryId}/chapters/{chapterContent.ChapterId}");
            var storyUrl = ToAbsolute($"/stories/{chapterContent.StoryId}");

            var chapterSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "Chapter",
                ["@id"] = chapterUrl,
                ["name"] = chapterContent.ChapterTitle,
                ["headline"] = chapterContent.ChapterTitle,
                ["url"] = chapterUrl,
                ["isPartOf"] = new Dictionary<string, object?>
                {
                    ["@type"] = "CreativeWork",
                    ["@id"] = storyUrl,
                    ["name"] = chapterContent.StoryTitle,
                    ["url"] = storyUrl
                },
                ["author"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Organization",
                    ["name"] = "IHeartFiction",
                    ["url"] = ToAbsolute("/")
                },
                ["publisher"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Organization",
                    ["name"] = "IHeartFiction",
                    ["url"] = ToAbsolute("/")
                },
                ["dateModified"] = chapterContent.ContentUpdatedAt.ToString("O")
            };

            var breadcrumbSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "BreadcrumbList",
                ["@id"] = ToAbsolute($"/stories/{chapterContent.StoryId}/chapters/{chapterContent.ChapterId}#breadcrumb"),
                ["itemListElement"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 1,
                        ["name"] = "Home",
                        ["item"] = ToAbsolute("/")
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 2,
                        ["name"] = "Stories",
                        ["item"] = ToAbsolute("/stories")
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 3,
                        ["name"] = chapterContent.StoryTitle,
                        ["item"] = storyUrl
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 4,
                        ["name"] = chapterContent.ChapterTitle,
                        ["item"] = chapterUrl
                    }
                }
            };

            return [chapterSchema, breadcrumbSchema];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadChapter();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (chapterContent?.ChapterId.ToString() != ChapterId)
        {
            await LoadChapter();
        }
    }

    private async Task LoadChapter()
    {
        isLoading = true;
        errorMessage = null;

        var result = await ChapterService.GetChapterContentAsync(ChapterId);

        if (result.IsSuccess)
        {
            chapterContent = result.Value;
        }
        else
        {
            errorMessage = result.DomainError.Description;
        }

        isLoading = false;
        StateHasChanged();
    }

    private string ChapterHref(string chapterId) => $"/stories/{StoryId}/chapters/{chapterId}";

    private string ToAbsolute(string url) => MetadataUrls.ToAbsolute(url);
}
