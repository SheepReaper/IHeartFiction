@using System.Globalization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.Extensions.Primitives

@inject NavigationManager Navigation
@inject AuthorService AuthorService

<div class="section">
    <div class="container">
        @if (EmitPaginationHeadLinks)
        {
            <SectionContent SectionName="@MetadataSectionName">
                @if (!string.IsNullOrEmpty(PreviousPageUrl))
                {
                    <link rel="prev" href="@PreviousPageUrl" />
                }

                @if (!string.IsNullOrEmpty(NextPageUrl))
                {
                    <link rel="next" href="@NextPageUrl" />
                }
            </SectionContent>
        }

        <div class="level">
            <div class="level-left">
                <div class="level-item">
                    <h1 class="title">Authors</h1>
                </div>
            </div>
            <div class="level-right">
                <div class="level-item">
                    <div class="field has-addons">
                        <div class="control has-icons-left">
                            <input class="input" type="text" placeholder="Search authors..." @bind="searchQuery" @onkeypress="OnSearchKeyPress">
                            <span class="icon is-small is-left">
                                <i class="fas fa-search"></i>
                            </span>
                        </div>
                        <div class="control">
                            <button class="button is-primary" @onclick="SearchAuthors">
                                Search
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="field">
            <div class="control">
                <div class="select">
                    <select @bind="sortBy" @bind:after="OnSortChanged">
                        <option value="name">Sort by Name</option>
                        <option value="createdAt">Sort by Join Date</option>
                        <option value="updatedAt">Sort by Last Activity</option>
                    </select>
                </div>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="has-text-centered">
                <div class="is-loading" style="height: 200px; display: flex; align-items: center; justify-content: center;">
                    <span class="icon is-large">
                        <i class="fas fa-spinner fa-pulse fa-2x"></i>
                    </span>
                </div>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="notification is-danger">
                <button class="delete" @onclick="ClearError"></button>
                <strong>Error:</strong> @errorMessage
            </div>
        }
        else if (authors?.Data?.Any() == true)
        {
            <div class="columns is-multiline">
                @foreach (var author in displayedAuthors)
                {
                    <div @key="author.Id" class="column @(IsCompact ? "is-full" : "is-one-third")">
                        <AuthorCard Author="author" />
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(LoadMoreUrl))
            {
                <div class="has-text-centered mt-5">
                    <a class="button has-background-link-soft has-text-link-bold is-medium @(isLoadingMore ? "is-loading" : string.Empty)"
                       href="@LoadMoreUrl"
                       rel="next"
                       aria-disabled="@isLoadingMore"
                       @onclick="LoadMoreAuthors"
                       @onclick:preventDefault="true">
                        Load more authors
                    </a>
                </div>
            }

            <SeoPaginationNav PreviousUrl="@PreviousPageUrl" NextUrl="@NextPageUrl" />
        }
        else
        {
            <div class="has-text-centered">
                <div class="content">
                    <span class="icon is-large">
                        <i class="fas fa-users fa-3x"></i>
                    </span>
                    <h3 class="title is-4">No authors found</h3>
                    <p>Try adjusting your search criteria.</p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "page")]
    public int? Page { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "sort")]
    public string? Sort { get; set; }

    [Parameter] public bool EmitPaginationHeadLinks { get; set; } = true;
    [Parameter] public string MetadataSectionName { get; set; } = "social-preview-extra-head";
    [CascadingParameter(Name = "IsCompact")] public bool IsCompact { get; set; }

    private static readonly string[] AllowedSorts = ["name", "createdAt", "updatedAt"];
    private const string DefaultSort = "name";

    private LinkedPagedCollectionOfListAuthorsItem? authors;
    private bool isLoading = true;
    private bool isLoadingMore;
    private string? errorMessage;
    private string searchQuery = "";
    private string sortBy = "name";
    private int currentPage = 1;
    private const int pageSize = 12;

    private int _loadedPage = -1;
    private string? _loadedSearch;
    private string? _loadedSort;
    private List<LinkedOfListAuthorsItem> displayedAuthors = [];
    private string? loadMoreUrl;

    private string? PreviousPageUrl => ResolveLinkedPageUrl("previous-page");
    private string? NextPageUrl => ResolveLinkedPageUrl("next-page");
    private string? LoadMoreUrl => loadMoreUrl;

    protected override async Task OnParametersSetAsync()
    {
        currentPage = NormalizePage(Page);
        searchQuery = Query ?? string.Empty;
        sortBy = NormalizeSort(Sort);

        if (currentPage == _loadedPage
            && string.Equals(searchQuery, _loadedSearch, StringComparison.Ordinal)
            && string.Equals(sortBy, _loadedSort, StringComparison.Ordinal))
        {
            return;
        }

        await LoadAuthors();
        _loadedPage = currentPage;
        _loadedSearch = searchQuery;
        _loadedSort = sortBy;
    }

    private async Task LoadAuthors()
    {
        isLoading = true;
        isLoadingMore = false;
        errorMessage = null;

        var result = await AuthorService.ListAuthorsAsync(
            page: currentPage,
            pageSize: pageSize,
            search: string.IsNullOrWhiteSpace(searchQuery) ? null : searchQuery,
            sort: sortBy);

        if (result.IsSuccess)
        {
            authors = result.Value;
            displayedAuthors = authors.Data.ToList();
            loadMoreUrl = NextPageUrl;
        }
        else
        {
            errorMessage = result.DomainError.Description;
            displayedAuthors = [];
            loadMoreUrl = null;
        }

        isLoading = false;
        StateHasChanged();
    }

    private Task SearchAuthors()
    {
        NavigateToPage(1);
        return Task.CompletedTask;
    }

    private async Task OnSearchKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchAuthors();
        }
    }

    private void OnSortChanged()
    {
        NavigateToPage(1);
    }

    private async Task LoadMoreAuthors()
    {
        if (isLoadingMore || string.IsNullOrWhiteSpace(LoadMoreUrl))
        {
            return;
        }

        var nextPage = TryGetPageFromUiHref(LoadMoreUrl);
        if (nextPage is null)
        {
            Navigation.NavigateTo(LoadMoreUrl);
            return;
        }

        isLoadingMore = true;
        errorMessage = null;

        var result = await AuthorService.ListAuthorsAsync(
            page: nextPage.Value,
            pageSize: pageSize,
            search: string.IsNullOrWhiteSpace(searchQuery) ? null : searchQuery,
            sort: sortBy);

        if (result.IsSuccess)
        {
            foreach (var author in result.Value.Data)
            {
                displayedAuthors.Add(author);
            }

            loadMoreUrl = ResolveLinkedPageUrl(result.Value, "next-page");
        }
        else
        {
            errorMessage = result.DomainError.Description;
        }

        isLoadingMore = false;
        StateHasChanged();
    }

    private string? ResolveLinkedPageUrl(string relation)
    {
        if (authors is null)
        {
            return null;
        }

        return ResolveLinkedPageUrl(authors, relation);
    }

    private string? ResolveLinkedPageUrl(LinkedPagedCollectionOfListAuthorsItem source, string relation)
    {
        var href = source.Links.FirstOrDefault(l => l.Rel == relation)?.Href;
        if (string.IsNullOrWhiteSpace(href))
        {
            return null;
        }

        return NormalizeApiHrefToUiListHref(href);
    }

    private void NavigateToPage(int page)
    {
        Navigation.NavigateTo(BuildPageUrl(page));
    }

    private string BuildPageUrl(int page)
    {
        var path = GetCurrentPath();
        var query = new Dictionary<string, string?>();

        if (page > 1)
        {
            query["page"] = page.ToString(CultureInfo.InvariantCulture);
        }

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query["q"] = searchQuery;
        }

        if (!string.Equals(sortBy, DefaultSort, StringComparison.OrdinalIgnoreCase))
        {
            query["sort"] = sortBy;
        }

        return query.Count == 0
            ? path
            : QueryHelpers.AddQueryString(path, query);
    }

    private string NormalizeApiHrefToUiListHref(string href)
    {
        var query = ParseQueryFromHref(href);
        var path = GetCurrentPath();
        var normalizedQuery = new Dictionary<string, string?>();

        var pageValue = GetQueryValue(query, "page");
        if (int.TryParse(pageValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var page) && page > 1)
        {
            normalizedQuery["page"] = page.ToString(CultureInfo.InvariantCulture);
        }

        var searchValue = GetQueryValue(query, "q") ?? GetQueryValue(query, "search");
        if (!string.IsNullOrWhiteSpace(searchValue))
        {
            normalizedQuery["q"] = searchValue;
        }

        var sortValue = GetQueryValue(query, "sort");
        if (!string.IsNullOrWhiteSpace(sortValue)
            && !string.Equals(sortValue, DefaultSort, StringComparison.OrdinalIgnoreCase))
        {
            normalizedQuery["sort"] = sortValue;
        }

        return normalizedQuery.Count == 0
            ? path
            : QueryHelpers.AddQueryString(path, normalizedQuery);
    }

    private Dictionary<string, StringValues> ParseQueryFromHref(string href)
    {
        if (Uri.TryCreate(href, UriKind.Absolute, out var absolute))
        {
            return QueryHelpers.ParseQuery(absolute.Query);
        }

        var baseUri = new Uri(Navigation.BaseUri);
        var resolved = new Uri(baseUri, href);
        return QueryHelpers.ParseQuery(resolved.Query);
    }

    private static string? GetQueryValue(Dictionary<string, StringValues> query, string key)
        => query.TryGetValue(key, out var values)
            ? values.FirstOrDefault(v => !string.IsNullOrWhiteSpace(v))
            : null;

    private int? TryGetPageFromUiHref(string href)
    {
        var query = ParseQueryFromHref(href);
        var pageValue = GetQueryValue(query, "page");

        return int.TryParse(pageValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var page) && page > 0
            ? page
            : null;
    }

    private string GetCurrentPath()
    {
        var relativeUri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var path = relativeUri.Split('?', 2)[0];

        return string.IsNullOrWhiteSpace(path)
            ? "/"
            : $"/{path.TrimStart('/')}";
    }

    private static int NormalizePage(int? page) => page is > 0 ? page.Value : 1;

    private static string NormalizeSort(string? sort) => AllowedSorts.Contains(sort) ? sort! : DefaultSort;

    private void ClearError()
    {
        errorMessage = null;
    }
}
