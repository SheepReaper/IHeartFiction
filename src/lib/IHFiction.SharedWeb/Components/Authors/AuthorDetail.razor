@using Markdig
@using IHFiction.SharedWeb.Components.Stories
@inject AuthorService AuthorService
@inject MarkdownPipeline mdp
@inject MetadataUrlService MetadataUrls
@using IHFiction.SharedWeb.Components.Notifications

<SocialPreviewMetadata
    Title="@MetadataTitle"
    Description="@MetadataDescription"
    ImageUrl="@MetadataImageUrl"
    Type="profile" />

<StructuredDataMetadata Schemas="@StructuredDataSchemas" />

@if (isLoading)
{
    <div class="section">
        <div class="container has-text-centered">
            <span class="icon is-large">
                <i class="fas fa-spinner fa-pulse fa-2x"></i>
            </span>
            <p>Loading author details...</p>
        </div>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="section">
        <div class="container">
            <div class="notification is-danger">
                <strong>Error:</strong> @errorMessage
            </div>
        </div>
    </div>
}
else if (author != null)
{
    <div class="section">
        <div class="container">
            <div class="columns">
                <div class="column is-one-quarter" style="min-width: 20rem;">
                    <div class="card">
                        <div class="card-content has-text-centered">
                            <figure class="image is-128x128 is-inline-block">
                                @if (!string.IsNullOrWhiteSpace(author.AvatarUrl))
                                {
                                    <img class="is-rounded" src="@author.AvatarUrl" alt="@author.Name" loading="lazy" />
                                }
                                else
                                {
                                    <div class="ihf-avatar-badge is-flex is-align-items-center is-justify-content-center" 
                                         style="width: 128px; height: 128px; border-radius: 50%;">
                                        <span class="title is-2">@GetInitials(author.Name)</span>
                                    </div>
                                }
                            </figure>
                            <h1 class="title is-3 mt-4">@author.Name</h1>
                            <div class="ihf-follow-panel has-text-left">
                                <p class="has-text-weight-semibold mb-2">Follow updates</p>
                                <p class="help">Get notified when this author publishes new stories.</p>
                                <AuthorFollowButton AuthorId="@AuthorId" />
                            </div>
                            <div class="tags is-centered mt-5">
                                <span class="tag is-primary">
                                    <span class="icon">
                                        <i class="fas fa-calendar"></i>
                                    </span>
                                    <span>Joined @author.UpdatedAt.ToString("MMM yyyy")</span>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="column">
                    <div class="content">
                        <h2 class="title is-4">About</h2>
                        @if (!string.IsNullOrWhiteSpace(author.Profile.Bio))
                        {
                            <div class="content">
                                @((MarkupString)Markdown.ToHtml(author.Profile.Bio, mdp))
                            </div>
                        }
                        else
                        {
                            <p>
                                <em>This author hasn't written a biography yet.</em>
                            </p>
                        }

                        @if (author.Profile.SocialLinks?.Any() == true)
                        {
                            <h3 class="title is-5 mt-5">Links</h3>
                            <div class="buttons">
                                @foreach (var link in author.Profile.SocialLinks)
                                {
                                    <a class="button is-light"
                                       href="@link.Value"
                                       target="_blank"
                                       rel="noopener noreferrer nofollow"
                                       title="@GetSocialLinkLabel(link.Type)">
                                        <span class="icon"><i class="@GetSocialLinkIcon(link.Type)"></i></span>
                                        <span>@GetSocialLinkLabel(link.Type)</span>
                                    </a>
                                }
                            </div>
                        }

                        <div class="columns is-mobile">
                            <div class="column">
                                <div class="has-text-centered">
                                    <p class="title is-2">@author.TotalStories</p>
                                    <p class="subtitle is-6">Total Stories</p>
                                </div>
                            </div>
                            <div class="column">
                                <div class="has-text-centered">
                                    <p class="title is-2">@author.PublishedStories.Count</p>
                                    <p class="subtitle is-6">Published</p>
                                </div>
                            </div>
                        </div>

                        @if (author.PublishedStories.Any())
                        {
                            <h3 class="title is-5">Stories</h3>
                            <SharedStoryList
                                Items="BuildAuthorPublishedStoryItems()"
                                EmptyStateTitle="No stories found"
                                EmptyStateMessage="This author hasn't published any stories yet." />
                        }
                        else
                        {
                            <div class="has-text-centered mt-6">
                                <span class="icon is-large">
                                    <i class="fas fa-book fa-2x"></i>
                                </span>
                                <p>This author hasn't published any stories yet.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public string AuthorId { get; set; } = null!;

    private LinkedOfGetAuthorResponse? author;
    private bool isLoading = true;
    private string? errorMessage;

    private string MetadataTitle => author is null
        ? "Author Profile | I❤️Fiction"
        : $"{author.Name} - Author Profile | I❤️Fiction";

    private string MetadataDescription => author switch
    {
        null => "Explore author profiles, published stories, and creator updates on IHeartFiction.",
        _ when !string.IsNullOrWhiteSpace(author.Profile.Bio) => author.Profile.Bio!,
        _ => $"Read stories by {author.Name} on IHeartFiction. {author.PublishedStories.Count} published {(author.PublishedStories.Count == 1 ? "story" : "stories")}."
    };

    private string? MetadataImageUrl => author?.AvatarUrl;

    private IEnumerable<object> StructuredDataSchemas
    {
        get
        {
            if (author is null)
            {
                return [];
            }

            var authorUrl = ToAbsolute($"/authors/{AuthorId}");
            var profileSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "ProfilePage",
                ["@id"] = authorUrl,
                ["url"] = authorUrl,
                ["mainEntity"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Person",
                    ["@id"] = ToAbsolute($"/authors/{AuthorId}#person"),
                    ["name"] = author.Name,
                    ["description"] = string.IsNullOrWhiteSpace(author.Profile.Bio) ? null : author.Profile.Bio,
                    ["url"] = authorUrl,
                    ["image"] = string.IsNullOrWhiteSpace(author.AvatarUrl) ? null : ToAbsolute(author.AvatarUrl),
                    ["sameAs"] = author.Profile.SocialLinks?
                        .Select(link => link.Value)
                        .Where(value => !string.IsNullOrWhiteSpace(value))
                        .ToList()
                }
            };

            var breadcrumbSchema = new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "BreadcrumbList",
                ["@id"] = ToAbsolute($"/authors/{AuthorId}#breadcrumb"),
                ["itemListElement"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 1,
                        ["name"] = "Home",
                        ["item"] = ToAbsolute("/")
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 2,
                        ["name"] = "Authors",
                        ["item"] = ToAbsolute("/authors")
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 3,
                        ["name"] = author.Name,
                        ["item"] = authorUrl
                    }
                }
            };

            return [profileSchema, breadcrumbSchema];
        }
    }

    private string ToAbsolute(string url) => MetadataUrls.ToAbsolute(url);

    protected override async Task OnInitializedAsync()
    {
        await LoadAuthor();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (author?.UserId.ToString() != AuthorId)
        {
            await LoadAuthor();
        }
    }

    private async Task LoadAuthor()
    {
        isLoading = true;
        errorMessage = null;

        var result = await AuthorService.GetAuthorAsync(AuthorId);

        if (result.IsSuccess)
        {
            author = result.Value;
        }
        else
        {
            errorMessage = result.DomainError.Description;
        }

        isLoading = false;
        StateHasChanged();
    }

    private List<StoryListDisplayItem> BuildAuthorPublishedStoryItems()
    {
        return author?.PublishedStories.Select(StoryListDisplayAdapters.FromAuthorWorkItem).ToList() ?? [];
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return "?";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpper();
        
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpper();
    }

    private static string GetSocialLinkLabel(string? type)
    {
        return type?.Trim().ToLowerInvariant() switch
        {
            "patreon" => "Patreon",
            _ => string.IsNullOrWhiteSpace(type) ? "Social Link" : type
        };
    }

    private static string GetSocialLinkIcon(string? type)
    {
        return type?.Trim().ToLowerInvariant() switch
        {
            "patreon" => "fab fa-patreon",
            _ => "fas fa-link"
        };
    }
}
