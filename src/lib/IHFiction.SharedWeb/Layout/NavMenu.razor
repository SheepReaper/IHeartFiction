@using IHFiction.SharedKernel.Infrastructure
@using IHFiction.SharedWeb.Services
@using Microsoft.Extensions.Configuration
@rendermode RenderMode.InteractiveServer
@inherits CancellableComponent
@inject ThemeService theme
@inject ViewPreferencesService viewPreferences
@inject IConfiguration config
@inject NavigationManager Navigation
@inject IJSRuntime JS

<!DOCTYPE html>

<nav class="navbar is-primary" role="navigation" aria-label="main navigation" @ref="_navbarRootRef">
    <div class="navbar-brand">
        <NavLink class="navbar-item" href="" Match="NavLinkMatch.All" @onclick="CloseMobileMenu">
            <strong>I❤️Fiction</strong>
        </NavLink>

        <a role="button" class="navbar-burger" aria-label="menu" aria-expanded="@(_isMobileMenuOpen ? "true" : "false")" data-target="navbarBasicExample"
            @onclick="ToggleMobileMenu" @onkeydown="HandleBurgerKeydown" tabindex="0">
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
            <span aria-hidden="true"></span>
        </a>
    </div>

    <div id="navbarBasicExample" class="navbar-menu @(_isMobileMenuOpen ? "is-active" : "")">
        <div class="navbar-start">
            <NavLink class="navbar-item" href="stories" @onclick="CloseMobileMenu">
                <span class="icon">
                    <i class="fas fa-book"></i>
                </span>
                <span>Stories</span>
            </NavLink>

            <NavLink class="navbar-item" href="authors" @onclick="CloseMobileMenu">
                <span class="icon">
                    <i class="fas fa-users"></i>
                </span>
                <span>Authors</span>
            </NavLink>

            <NavLink class="navbar-item" href="following" @onclick="CloseMobileMenu">
                <span class="icon">
                    <i class="fas fa-bell"></i>
                </span>
                <span>Following</span>
            </NavLink>
            <AuthorizeView>
                <Authorized>
                    @if (context.User.IsInRole("author"))
                    {
                        <NavLink class="navbar-item" href="my-stories" @onclick="CloseMobileMenu">
                            <span class="icon">
                                <i class="fas fa-book-open"></i>
                            </span>
                            <span>My Stories</span>
                        </NavLink>
                    }
                    else
                    {
                        <NavLink class="navbar-item" href="become-author" @onclick="CloseMobileMenu">
                            <span class="icon">
                                <i class="fas fa-pen-nib"></i>
                            </span>
                            <span>Start Writing</span>
                        </NavLink>
                    }
                </Authorized>
            </AuthorizeView>
        </div>

        <div class="navbar-end">
            <div class="navbar-item">
                <LoginDisplay OnActionInvoked="CloseMobileMenuAsync" />
            </div>
            <div class="navbar-item ihf-nav-api-docs">
                <a class="button is-info" href="@DocsUrl" target="_blank" rel="noopener noreferrer" @onclick="CloseMobileMenu">
                    <span class="icon"><i class="fas fa-book-medical"></i></span>
                    <span>API Docs</span>
                </a>
            </div>
            <div class="navbar-item ihf-nav-actions">
                <div class="buttons">
                    <a class="button has-background-link-soft has-text-link-bold has-tooltip-bottom" data-tooltip="About" href="/about" aria-label="About" @onclick="CloseMobileMenu">
                        <span class="icon"><i class="@CurrentCycleIcon"></i></span>
                    </a>
                    <button class="button has-background-warning-soft has-text-warning-bold has-tooltip-bottom" data-tooltip="Hit the lights" @onclick="ToggleThemeAndCloseMenu" aria-label="Hit the lights">
                        <span class="icon"><i class="fas fa-@themeIcon"></i></span>
                    </button>
                    <button class="button has-background-success-soft has-text-success-bold has-tooltip-bottom" data-tooltip="@compactToggleTooltip" @onclick="ToggleCompactAndCloseMenu" aria-label="@compactToggleTooltip">
                        <span class="icon"><i class="fas fa-@compactToggleIcon"></i></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</nav>

@code {
    private bool _isMobileMenuOpen = false;
    private string themeIcon => theme.CurrentTheme == "dark" ? "sun" : "moon";
    private string compactToggleIcon => viewPreferences.IsCompact ? "th-large" : "th-list";
    private string compactToggleTooltip => viewPreferences.IsCompact ? "Expanded view" : "Compact view";
    private bool _disposed = false;
    private ElementReference _navbarRootRef;
    private IJSObjectReference? _module;
    private IJSObjectReference? _outsideClickListener;
    private DotNetObjectReference<NavMenu>? _dotNetReference;

    private string DocsUrl => config["ApiBaseAddress"] is string apiBaseAddress
        ? $"{apiBaseAddress.TrimEnd('/')}/scalar/v1"
        : "#";

    private System.Threading.Timer? _iconTimer;
    private int _iconIndex = 0;
    private readonly (string Icon, string Name)[] _cycleIcons = new[]
    {
        ("fas fa-question-circle", "Help"),
        ("fab fa-github", "GitHub"),
        @* ("fab fa-kofi", "Ko-fi"), *@
        ("fab fa-patreon", "Patreon"),
        ("fas fa-mug-hot", "Buy Me a Coffee")
    };

    private string CurrentCycleIcon => _cycleIcons[_iconIndex].Icon;

    protected override Task OnInitializedAsync()
    {
        theme.ThemeChanged += OnThemeChanged;
        viewPreferences.CompactModeChanged += OnCompactModeChanged;
        Navigation.LocationChanged += OnLocationChanged;

        // start icon rotation (every 3s)
        _iconTimer = new System.Threading.Timer(_ =>
        {
            _iconIndex = (_iconIndex + 1) % _cycleIcons.Length;
            InvokeAsync(StateHasChanged);
        }, null, 3000, 3000);

        return Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await theme.InitializeThemeAsync(CancellationToken);

            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./_content/IHFiction.SharedWeb/Layout/NavMenu.razor.js");

            _dotNetReference = DotNetObjectReference.Create(this);
            _outsideClickListener = await _module.InvokeAsync<IJSObjectReference>(
                "registerOutsideClickListener",
                _navbarRootRef,
                _dotNetReference);
        }
    }

    private void ToggleMobileMenu()
    {
        _isMobileMenuOpen = !_isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        if (!_isMobileMenuOpen)
        {
            return;
        }

        _isMobileMenuOpen = false;
        _ = InvokeAsync(StateHasChanged);
    }

    private Task CloseMobileMenuAsync()
    {
        CloseMobileMenu();
        return InvokeAsync(StateHasChanged);
    }

    private void HandleBurgerKeydown(KeyboardEventArgs e)
    {
        // Toggle menu on Enter or Space key
        if (e.Key == "Enter" || e.Key == " ")
        {
            ToggleMobileMenu();
        }
    }

    private async Task ToggleThemeAndCloseMenu()
    {
        await CloseMobileMenuAsync();
        await theme.ToggleThemeAsync(CancellationToken);
    }

    private async Task ToggleCompactAndCloseMenu()
    {
        await CloseMobileMenuAsync();
        await viewPreferences.ToggleCompactAsync(CancellationToken);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (IsCloseExemptLocation(e.Location))
        {
            return;
        }

        CloseMobileMenu();
    }

    private bool IsCloseExemptLocation(string location)
    {
        var relativePath = Navigation.ToBaseRelativePath(location);

        return relativePath.StartsWith("authentication/login", StringComparison.OrdinalIgnoreCase);
    }

    [JSInvokable]
    public Task HandleOutsideClick()
    {
        return CloseMobileMenuAsync();
    }

    private void OnThemeChanged(object? sender, ThemeChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnCompactModeChanged(object? sender, CompactModeChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async ValueTask DisposeAsyncCore()
    {
        if(_disposed) return;

        theme.ThemeChanged -= OnThemeChanged;
        viewPreferences.CompactModeChanged -= OnCompactModeChanged;
        Navigation.LocationChanged -= OnLocationChanged;

        if (_iconTimer is not null)
        {
            await _iconTimer.DisposeAsync();
        }

        if (_outsideClickListener is not null)
        {
            try
            {
                await _outsideClickListener.InvokeVoidAsync("dispose");
                await _outsideClickListener.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Blazor is disconnecting and JS runtime is no longer available.
            }
        }

        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Blazor is disconnecting and JS runtime is no longer available.
            }
        }

        _dotNetReference?.Dispose();

        _disposed = true;

        await base.DisposeAsyncCore();
    }
}