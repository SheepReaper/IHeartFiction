@inherits LayoutComponentBase
@inject Microsoft.Extensions.Hosting.IHostEnvironment HostEnvironment
@inject IHFiction.SharedWeb.Services.ViewPreferencesService ViewPreferences
@implements IDisposable

<NavMenu />

<main class="section">
    <div class="container">
        <CascadingValue Value="ViewPreferences.IsCompact" Name="IsCompact" IsFixed="false">
            @Body
        </CascadingValue>
    </div>
</main>

<Loader />

@if (string.Equals(HostEnvironment.EnvironmentName, "Development", StringComparison.OrdinalIgnoreCase))
{
    <div id="blazor-error-ui" data-nosnippet class="notification is-danger is-hidden">
        <button class="delete" onclick="document.getElementById('blazor-error-ui').classList.add('is-hidden')"></button>
        <strong>An unhandled error has occurred.</strong>
        <a href="." class="button is-small has-background-danger-soft has-text-danger-bold ml-2">Reload</a>
    </div>
}

@code {
    private bool _disposed;

    protected override void OnInitialized()
    {
        ViewPreferences.CompactModeChanged += OnCompactModeChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await ViewPreferences.InitializeAsync();
    }

    private void OnCompactModeChanged(object? sender, IHFiction.SharedWeb.Services.CompactModeChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        if (_disposed)
        {
            return;
        }

        ViewPreferences.CompactModeChanged -= OnCompactModeChanged;
        _disposed = true;
    }
}